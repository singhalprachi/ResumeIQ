OPENAI_API_KEY=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

# ---- App Settings ----
APP_ENV=development
SECRET_KEY=generate-a-random-secret-key-here

# ---- CORS (comma-separated, no spaces) ----
# Add your Vercel URL once deployed
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ---- ChromaDB ----
# For Railway, use /tmp/chroma_db or mount a volume
CHROMA_PERSIST_DIR=./chroma_db

# ---- Optional Tuning ----
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_CHUNKS=8
MAX_FILE_SIZE_MB=10
